{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "check": "tsc --noEmit",
    "deploy": "wrangler deploy --minify",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand",
    "test:load:smoke:local": "artillery run load-tests/smoke.yml -e local",
    "test:load:smoke:ci": "artillery run load-tests/smoke.yml -e ci",
    "test:load:smoke:staging": "artillery run load-tests/smoke.yml -e staging",
    "test:load:student:local": "artillery run load-tests/student-flow.yml -e local",
    "test:load:student:staging": "artillery run load-tests/student-flow.yml -e staging",
    "test:load:teacher:local": "artillery run load-tests/teacher-reads.yml -e local",
    "test:load:teacher:staging": "artillery run load-tests/teacher-reads.yml -e staging",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply pinequest-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply pinequest-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "artillery": "^2.0.30",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "wrangler": "^4.76.0"
  }
}
